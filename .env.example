# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Clerk (https://dashboard.clerk.com)
# Use either (this project enables both prefixes in vite.config.js):
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Backend — same Clerk app, "Secret keys"
CLERK_SECRET_KEY=sk_test_...

# Optional
# PORT=8787
# DATABASE_PATH=./data/app.db
# On Vercel, the DB defaults to /tmp (ephemeral); use a hosted DB for persistent history and saved resumes.
