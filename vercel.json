{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.js": {
      "includeFiles": "node_modules/pdfjs-dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api?__vp="
    },
    {
      "source": "/api/",
      "destination": "/api?__vp="
    },
    {
      "source": "/api/:path*",
      "destination": "/api?__vp=:path*"
    }
  ]
}
